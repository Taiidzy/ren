# Ren DevOps Environment Variables
# Скопируйте этот файл в .env и заполните значениями

# ---------------------------
# Database (PostgreSQL)
# ---------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_HOST_PORT=5433
POSTGRES_DB=ren_messenger

# ---------------------------
# Backend
# ---------------------------
# Минимум 32 байта для HS256
JWT_SECRET=

# Порт бд
POSTGRES_PORT=5432

# CORS разрешённые origin (через запятую)
CORS_ALLOW_ORIGINS=
# Порт backend сервера
PORT=8081

# Level логирования (trace, debug, info, warn, error)
RUST_LOG=info

# ---------------------------
# Security
# ---------------------------
# Разрешённые SDK fingerprint (через запятую)
# Оставьте пустым для отключения проверки
SDK_FINGERPRINT_ALLOWLIST=

# HMAC secret для подписи API запросов
HMAC_SECRET=hfouisdhfuhdsiughfuydsgfcuykgsdkfjhgdskjgfasdf

# ---------------------------
# DevOps
# ---------------------------
# API key для CI/CD pipeline
DEVOPS_API_KEY=

# URL DevOps API (для CI/CD)
DEVOPS_API_URL=http://localhost:8081

# ---------------------------
# SSL/TLS (Production)
# ---------------------------
# Let's Encrypt email для уведомлений
LETSENCRYPT_EMAIL=

# Домен для SSL сертификата
SSL_DOMAIN=